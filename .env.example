# sumo-rl-loerrach Environment Variables
# Copy to .env and adjust paths for your machine

# SUMO installation path
# macOS (brew): /opt/homebrew/share/sumo
# Linux: /usr/share/sumo
# Windows: C:\Program Files (x86)\Eclipse\Sumo
SUMO_HOME=/opt/homebrew/share/sumo

# Random seed for reproducibility
GLOBAL_SEED=42

# Training device (cpu, cuda, mps)
DEVICE=cpu
