    <!-- N_end ↔ J_N (200m approach) -->
    <edge id="N_Jn"  from="N_end" to="J_N" numLanes="2" speed="13.89" priority="3"/>
    <edge id="Jn_N"  from="J_N" to="N_end" numLanes="2" speed="13.89" priority="3"/>

    <!-- J_N ↔ C (250m between intersections) -->
    <edge id="Jn_C"  from="J_N" to="C"   numLanes="2" speed="13.89" priority="3"/>
    <edge id="C_Jn"  from="C"   to="J_N" numLanes="2" speed="13.89" priority="3"/>

    <!-- C ↔ J_S (250m between intersections) -->
    <edge id="C_Js"  from="C"   to="J_S" numLanes="2" speed="13.89" priority="3"/>
