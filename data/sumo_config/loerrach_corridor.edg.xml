    <edge id="Jn_En" from="J_N" to="En" numLanes="1" speed="13.89" priority="2"/>

    <!-- === Cross street at C: Querstraße (1 lane) === -->
    <edge id="W_C"   from="W"  to="C"  numLanes="1" speed="13.89" priority="2"/>
    <edge id="C_W"   from="C"  to="W"  numLanes="1" speed="13.89" priority="2"/>
    <edge id="E_C"   from="E"  to="C"  numLanes="1" speed="13.89" priority="2"/>
    <edge id="C_E"   from="C"  to="E"  numLanes="1" speed="13.89" priority="2"/>

    <!-- === Cross street at J_S: Brühlstraße (1 lane) === -->
    <edge id="Ws_Js" from="Ws" to="J_S" numLanes="1" speed="13.89" priority="2"/>
    <edge id="Js_Ws" from="J_S" to="Ws" numLanes="1" speed="13.89" priority="2"/>
    <edge id="Es_Js" from="Es" to="J_S" numLanes="1" speed="13.89" priority="2"/>
    <edge id="Js_Es" from="J_S" to="Es" numLanes="1" speed="13.89" priority="2"/>
